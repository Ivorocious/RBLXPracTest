{
  "name": "PracticeAndTest",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "$className": "ReplicatedStorage",
      "Shared": {
        "$path": "src/ReplicatedStorage/Shared"
      },
      "Config": {
        "$className": "Folder",
        "$path": "src/ReplicatedStorage/Config"
      },
      "Remotes": {
        "$className": "Folder",
        "$path": "src/ReplicatedStorage/Remotes"
      }
    },

    "ServerScriptService": {
      "$className": "ServerScriptService",
      "Main": {
        "$path": "src/ServerScriptService/Main.server.luau"
      },
      "Services": {
        "$className": "Folder",
        "$path": "src/ServerScriptService/Services"
      }
    },

    "StarterPlayer": {
      "$className": "StarterPlayer",
      "StarterPlayerScripts": {
        "$className": "StarterPlayerScripts",
        "$path": "src/StarterPlayer/StarterPlayerScripts"
      }
    },

    "StarterGui": {
      "$className": "StarterGui",
      "$path": "src/StarterGui"
    },

    "Workspace": {
      "$className": "Workspace",
      "$ignoreUnknownInstances": true
    },

    "Lighting": {
      "$className": "Lighting",
      "$ignoreUnknownInstances": true
    }
  }
}
